# Kopjo kete file ne `.env` dhe ploteso vlerat
PORT=4000

# PostgreSQL (krijo nje DB ne pgAdmin, p.sh. "iq_tester")
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=iq_tester

# Sekret per nenshkrimin e JWT-ve (perdor nje string te gjate random ne produksion)
JWT_SECRET=zevendeso-me-nje-sekret-te-gjate-random
JWT_EXPIRES_IN=7d

# Origin i lejuar per CORS (Vite default 5173)
CLIENT_ORIGIN=http://localhost:5173

# Konfigurimi i testit
QUIZ_QUESTIONS_PER_ATTEMPT=20
QUIZ_TIME_LIMIT_MINUTES=15
