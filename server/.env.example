# Kopjo kete file ne `.env` dhe ploteso vlerat
PORT=4000

# ---- Database ----
# Opsioni A: kredencialet e ndara (development lokal)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=iq_tester

# Opsioni B (per Neon/produksion): connection string e plote
# Nese DATABASE_URL eshte caktuar, ka prioritet mbi opsionin A.
# DATABASE_URL=postgresql://user:pass@xxx.neon.tech/iq_tester?sslmode=require

# ---- JWT ----
JWT_SECRET=zevendeso-me-nje-sekret-te-gjate-random
JWT_EXPIRES_IN=7d

# ---- CORS ----
# Lokal: http://localhost:5173
# Produksion: ndaj me presje, p.sh. https://iq-tester.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# ---- Quiz ----
QUIZ_QUESTIONS_PER_ATTEMPT=20
QUIZ_TIME_LIMIT_MINUTES=15
